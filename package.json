{
  "name": "@moeyua/skills",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Moeyua's personal skills for AI coding assistants",
  "author": "Moeyua <mail@moeyua.com>",
  "license": "MIT",
  "scripts": {
    "lint": "eslint .",
    "start": "node scripts/cli.ts",
    "prepare": "simple-git-hooks && git submodule update --init --recursive"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.2",
    "@types/node": "^24.0.0",
    "eslint": "^9.27.0",
    "lint-staged": "^16.1.0",
    "simple-git-hooks": "^2.12.1",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix"
  }
}
